# -----------------------------------------------------------------------------
# 安全警告: 请勿使用默认密码部署
# 对于非本地部署,请将所有密码(ELASTIC_PASSWORD、MYSQL_PASSWORD、MINIO_PASSWORD等)
# 修改为强密码。你可以运行以下命令生成随机字符串: openssl rand -hex 32
# -----------------------------------------------------------------------------

# ------------------------------
# Docker 环境变量，用于指定启动时的向量数据库类型
# (根据向量数据库类型，使用对应的 docker compose profile)
# ------------------------------
# 文档引擎类型。可选值：
# - `elasticsearch` (默认)
# - `infinity` (https://github.com/infiniflow/infinity)
# - `oceanbase` (https://github.com/oceanbase/oceanbase)
# - `opensearch` (https://github.com/opensearch-project/OpenSearch)
# - `seekdb` (https://github.com/oceanbase/seekdb)
DOC_ENGINE=${DOC_ENGINE:-elasticsearch}

# DeepDoc 推理运行的设备类型。可选值：
# - `cpu` (默认)
# - `gpu`
DEVICE=${DEVICE:-cpu}
# Jayce.xin modify by 20260418 修改配置使用gpu
#DEVICE=gpu

# 组合 profile，根据 DOC_ENGINE 和 DEVICE 自动生成
COMPOSE_PROFILES=${DOC_ENGINE},${DEVICE}

# Elasticsearch 版本号
STACK_VERSION=${STACK_VERSION:-8.11.3}

# Elasticsearch 服务的主机名（在 Docker 网络内部使用）
ES_HOST=es01

# 向宿主机暴露的 Elasticsearch 端口，允许外部访问容器内的服务
ES_PORT=1200

# Elasticsearch 的密码
# 警告：生产环境请修改！
ELASTIC_PASSWORD=infini_rag_flow

# OpenSearch 服务的主机名（不要与 elasticsearch 相同）
OS_PORT=1201

# OpenSearch 服务的主机名
OS_HOST=opensearch01

# OpenSearch 的密码
# 密码要求：至少包含一个大写字母、一个小写字母、一个数字和一个特殊字符
OPENSEARCH_PASSWORD=infini_rag_flow_OS_01

# 向宿主机暴露的 Kibana 端口，允许外部访问容器内的 Kibana 可视化界面
# 启用 Kibana 的步骤：
# 1. 确保 COMPOSE_PROFILES 包含 kibana，例如：COMPOSE_PROFILES=${COMPOSE_PROFILES},kibana
# 2. 在 docker-compose-base.yml 中注释或删除 es 服务的以下配置：
#    xpack.security.enabled、xpack.security.http.ssl.enabled、xpack.security.transport.ssl.enabled
# 3. 调整 conf/service_config.yaml 或 docker/service_conf.yaml.template 中的 es.hosts 为 'https://localhost:1200'
# 4. 启动成功后，在 es 容器内执行命令生成 kibana token：bin/elasticsearch-create-enrollment-token -s kibana
KIBANA_PORT=6601

# 单个 Docker 容器运行时可以使用的最大内存字节数
# 请根据宿主机的可用内存进行更新
MEM_LIMIT=8073741824

# Infinity 服务的宿主机名
INFINITY_HOST=infinity

# 向宿主机暴露的 Infinity API 端口
INFINITY_THRIFT_PORT=23817
INFINITY_HTTP_PORT=23820
INFINITY_PSQL_PORT=5432

# OceanBase 服务的宿主机名
OCEANBASE_HOST=oceanbase
# 向宿主机暴露的 OceanBase 服务端口
OCEANBASE_PORT=2881
# OceanBase 的用户名
OCEANBASE_USER=root@ragflow
# OceanBase 的密码
OCEANBASE_PASSWORD=infini_rag_flow
# OceanBase 的文档数据库名称
OCEANBASE_DOC_DBNAME=ragflow_doc

# OceanBase 容器配置
OB_CLUSTER_NAME=${OB_CLUSTER_NAME:-ragflow}
OB_TENANT_NAME=${OB_TENANT_NAME:-ragflow}
OB_SYS_PASSWORD=${OCEANBASE_PASSWORD:-infini_rag_flow}
OB_TENANT_PASSWORD=${OCEANBASE_PASSWORD:-infini_rag_flow}
OB_MEMORY_LIMIT=${OB_MEMORY_LIMIT:-10G}
OB_SYSTEM_MEMORY=${OB_SYSTEM_MEMORY:-2G}
OB_DATAFILE_SIZE=${OB_DATAFILE_SIZE:-20G}
OB_LOG_DISK_SIZE=${OB_LOG_DISK_SIZE:-20G}

# SeekDB 服务的宿主机名
SEEKDB_HOST=seekdb
# 向宿主机暴露的 SeekDB 服务端口
SEEKDB_PORT=2881
# SeekDB 的用户名
SEEKDB_USER=root
# SeekDB 的密码
SEEKDB_PASSWORD=infini_rag_flow
# SeekDB 的文档数据库名称
SEEKDB_DOC_DBNAME=ragflow_doc
# SeekDB 的内存限制
SEEKDB_MEMORY_LIMIT=2G

# MySQL 的密码
# 警告：生产环境请修改！
MYSQL_PASSWORD=infini_rag_flow
# MySQL 服务的宿主机名（在 Docker 网络内部使用）
MYSQL_HOST=mysql
# MySQL 的数据库名称
MYSQL_DBNAME=rag_flow
# 从 RAGFlow 容器连接 MySQL 的端口
# 如果使用外部 MySQL，请修改此端口
MYSQL_PORT=3306
# 向宿主机暴露的 MySQL 服务端口，允许外部访问容器内的 MySQL 数据库
EXPOSE_MYSQL_PORT=3306
# 发送到 MySQL 服务器的通信数据包最大大小
MYSQL_MAX_PACKET=1073741824

# MinIO 服务的宿主机名
MINIO_HOST=minio
# 向宿主机暴露的 MinIO 控制台端口，允许外部访问基于 Web 的控制台界面
MINIO_CONSOLE_PORT=9001
# 向宿主机暴露的 MinIO API 服务端口，允许外部访问 MinIO 对象存储服务
MINIO_PORT=9000
# MinIO 的用户名
# 更新后，请同时修改 service_conf.yaml 中的 minio.user 配置
MINIO_USER=rag_flow
# MinIO 的密码
# 更新后，请同时修改 service_conf.yaml 中的 minio.password 配置
MINIO_PASSWORD=infini_rag_flow

# Redis 服务的宿主机名
REDIS_HOST=redis
# 向宿主机暴露的 Redis 服务端口，允许外部访问容器内的 Redis 服务
REDIS_PORT=6379
# Redis 的密码
REDIS_PASSWORD=infini_rag_flow

# 向宿主机暴露的 RAGFlow HTTP API 服务端口，允许外部访问容器内的服务
#SVR_WEB_HTTP_PORT=80
#SVR_WEB_HTTPS_PORT=443
#SVR_HTTP_PORT=9380
#ADMIN_SVR_HTTP_PORT=9381
#SVR_MCP_PORT=9382
#GO_HTTP_PORT=9384
#GO_ADMIN_PORT=9383
#Jayce.xin modify by 20260418 修改配置使用的是自定义docker端口
SVR_WEB_HTTP_PORT=8010
SVR_WEB_HTTPS_PORT=8011
SVR_HTTP_PORT=9380
ADMIN_SVR_HTTP_PORT=9381
SVR_MCP_PORT=9382
GO_HTTP_PORT=9384
GO_ADMIN_PORT=9383
# API 代理模式
# API_PROXY_SCHEME=hybrid # Go 和 Python 混合部署模式
API_PROXY_SCHEME=python # 纯 Python 服务器部署模式

# RAGFlow Docker 镜像。v0.22+ 版本不包含 embedding 模型
#RAGFLOW_IMAGE=infiniflow/ragflow:latest
# Jayce.xin modify by 20260418 修改配置使用的是自定义镜像
RAGFLOW_IMAGE=lz-ragflow:v1.0

# 如果无法下载 RAGFlow Docker 镜像，可以使用以下国内镜像：
# RAGFLOW_IMAGE=swr.cn-north-4.myhuaweicloud.com/infiniflow/ragflow:v0.24.0
# RAGFLOW_IMAGE=registry.cn-hangzhou.aliyuncs.com/infiniflow/ragflow:v0.24.0
#
# 对于 nightly 版本，取消注释以下任一镜像源：
# RAGFLOW_IMAGE=swr.cn-north-4.myhuaweicloud.com/infiniflow/ragflow:nightly
# RAGFLOW_IMAGE=registry.cn-hangzhou.aliyuncs.com/infiniflow/ragflow:nightly

# Embedding 服务镜像、模型和端口配置
# 重要提示：启用 embedding 服务需要取消注释以下两行之一：
# COMPOSE_PROFILES=${COMPOSE_PROFILES},tei-cpu
# COMPOSE_PROFILES=${COMPOSE_PROFILES},tei-gpu

# Embedding 服务镜像
TEI_IMAGE_CPU=infiniflow/text-embeddings-inference:cpu-1.8
TEI_IMAGE_GPU=infiniflow/text-embeddings-inference:1.8

# Embedding 服务模型
# 可选模型：
# - `Qwen/Qwen3-Embedding-0.6B` (默认，需要 25GB RAM/vRAM)
# - `BAAI/bge-m3` (需要 21GB RAM/vRAM)
# - `BAAI/bge-small-en-v1.5` (需要 1.2GB RAM/vRAM)
TEI_MODEL=${TEI_MODEL:-Qwen/Qwen3-Embedding-0.6B}

# Embedding 服务宿主机名
TEI_HOST=tei
# 向宿主机暴露的 TEI 服务端口，允许外部访问容器内的 embedding 服务
TEI_PORT=6380

# 本地时区
TZ=Asia/Shanghai

# 如果访问 huggingface.co 受限，取消注释以下行使用镜像站点：
# HF_ENDPOINT=https://hf-mirror.com

# MacOS 优化配置
# 如果你的操作系统是 MacOS，取消注释以下行：
# MACOS=1

# 上传到数据集或 RAGFlow 文件系统的单个文件最大大小（字节）
# 要修改默认的 1GB 文件大小限制，取消注释下一行并更新为你需要的值
# MAX_CONTENT_LENGTH=1073741824
# 更新后，请同步更新 nginx/nginx.conf 中的 client_max_body_size
# 注意：MAX_CONTENT_LENGTH 和 client_max_body_size 都不会设置上传到 agent 的文件大小上限
# 详情见 https://ragflow.io/docs/dev/begin_component

# 控制每个批次处理的文档数量
# 如果未设置 DOC_BULK_SIZE，默认为 4
DOC_BULK_SIZE=${DOC_BULK_SIZE:-4}

# 生成 embedding 时每个批次处理的条目数量
# 如果未设置 EMBEDDING_BATCH_SIZE，默认为 16
EMBEDDING_BATCH_SIZE=${EMBEDDING_BATCH_SIZE:-16}

# RAGFlow 及其导入包的日志级别
# 可选级别：
# - `DEBUG`
# - `INFO` (默认)
# - `WARNING`
# - `ERROR`
# 示例：以下行将 ragflow.es_conn 的日志级别设置为 DEBUG：
# LOG_LEVELS=ragflow.es_conn=DEBUG

# 阿里云 OSS 配置
# STORAGE_IMPL=OSS
# ACCESS_KEY=xxx
# SECRET_KEY=eee
# ENDPOINT=http://oss-cn-hangzhou.aliyuncs.com
# REGION=cn-hangzhou
# BUCKET=ragflow65536
#

# 用户注册开关
# - 启用注册：1
# - 禁用注册：0
REGISTER_ENABLED=1

# 重要提示：要启用 sandbox，需要取消注释以下两行：
# SANDBOX_ENABLED=1
# COMPOSE_PROFILES=${COMPOSE_PROFILES},sandbox

# Sandbox 设置
# 首先确认你已将 sandbox-executor-manager 添加到 /etc/hosts
# 运行前先拉取所需的基础镜像：
#   docker pull infiniflow/sandbox-base-nodejs:latest
#   docker pull infiniflow/sandbox-base-python:latest
# 我们的默认 sandbox 环境包括：
#   - Node.js 基础镜像：包含 axios
#   - Python 基础镜像：包含 requests、numpy 和 pandas
# 如需使用非默认环境，请在下方指定自定义 executor 镜像
# SANDBOX_HOST=sandbox-executor-manager
# SANDBOX_EXECUTOR_MANAGER_IMAGE=infiniflow/sandbox-executor-manager:latest
# SANDBOX_EXECUTOR_MANAGER_POOL_SIZE=3
# SANDBOX_BASE_PYTHON_IMAGE=infiniflow/sandbox-base-python:latest
# SANDBOX_BASE_NODEJS_IMAGE=infiniflow/sandbox-base-nodejs:latest
# SANDBOX_EXECUTOR_MANAGER_PORT=9385
# SANDBOX_ENABLE_SECCOMP=false
# SANDBOX_MAX_MEMORY=256m # 单位：b, k, m, g
# SANDBOX_TIMEOUT=10s # 单位：s, m, 如 1m30s
# 用于存储 sandbox 生成的文件（图表、文件等）的 MinIO bucket 名称
SANDBOX_ARTIFACT_BUCKET=sandbox-artifacts
# Sandbox 文件在存储中自动删除前的天数
SANDBOX_ARTIFACT_EXPIRE_DAYS=7

# 启用 DocLing 是否使用 Docling（另一个文档解析库）
USE_DOCLING=false

# 启用 Mineru
# 取消注释以下行将在可能的情况下自动将 MinerU 添加到模型提供商
# 更多详情见 https://ragflow.io/docs/faq#how-to-use-mineru-to-parse-pdf-documents
# MINERU_DELETE_OUTPUT=0   # 保留输出目录
# MINERU_BACKEND=pipeline  # 或你喜欢的其他后端

# PPTX 支持
DOTNET_SYSTEM_GLOBALIZATION_INVARIANT=1

# 加密工具配置
# RAGFLOW_CRYPTO_ENABLED=true
# RAGFLOW_CRYPTO_ALGORITHM=aes-256-cbc # 可选：aes-256-cbc, aes-128-cbc, sm4-cbc
# RAGFLOW_CRYPTO_KEY=ragflow-crypto-key

# ThreadPoolExecutor 使用的最大工作线程数
THREAD_POOL_MAX_WORKERS=128

# 禁用密码登录表单的选项（用于 SSO）
# 禁用密码登录：true
# 启用密码登录：false
DISABLE_PASSWORD_LOGIN=false